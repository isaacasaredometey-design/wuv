<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta name="color-scheme" content="light dark">
  <title>For You — I Love You</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300,400,600,700&family=Manrope:wght@300,400,500,600,700&display=swap" rel="stylesheet">

  <style>
    :root{
      /* Romantic editorial: warm paper + ink + blush */
      --paper: #fbf6f0;
      --paper-2: #fffaf6;
      --ink: #1f1a18;
      --muted: rgba(31,26,24,.72);
      --soft: rgba(31,26,24,.12);

      --blush: #f2b6c4;
      --rose: #d65a75;
      --wine: #6b1d33;
      --gold: #b88b2a;

      --shadow: 0 20px 60px rgba(31,26,24,.10);
      --radius: 22px;

      --max: 1120px;
    }

    *{ box-sizing:border-box; }
    html, body { height: 100%; }
    body{
      margin:0;
      font-family: "Manrope", system-ui, -apple-system, Segoe UI, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(1200px 900px at 12% 8%, rgba(214,90,117,.12), transparent 60%),
        radial-gradient(900px 700px at 88% 20%, rgba(184,139,42,.12), transparent 55%),
        radial-gradient(1000px 800px at 70% 92%, rgba(242,182,196,.14), transparent 58%),
        linear-gradient(180deg, var(--paper), var(--paper-2));
      overflow-x:hidden;
    }

    /* Subtle paper grain (CSS-only) */
    body::before{
      content:"";
      position:fixed; inset:0;
      pointer-events:none;
      background:
        repeating-linear-gradient(0deg, rgba(31,26,24,.03), rgba(31,26,24,.03) 1px, transparent 1px, transparent 3px),
        repeating-linear-gradient(90deg, rgba(31,26,24,.02), rgba(31,26,24,.02) 1px, transparent 1px, transparent 4px);
      mix-blend-mode:multiply;
      opacity:.12;
    }

    a{ color:inherit; }
    ::selection{ background: rgba(214,90,117,.22); }

    .wrap{
      width:min(var(--max), calc(100% - 40px));
      margin: 0 auto;
    }

    /* Top ribbon nav */
    header{
      position:sticky;
      top:0;
      z-index:50;
      backdrop-filter: blur(10px);
      background: linear-gradient(180deg, rgba(251,246,240,.78), rgba(251,246,240,.55));
      border-bottom: 1px solid rgba(31,26,24,.08);
    }

    .nav{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding: 14px 0;
    }

    .brand{
      display:flex;
      align-items:baseline;
      gap:10px;
      letter-spacing:.02em;
      white-space:nowrap;
    }

    .brand .sig{
      font-family:"Fraunces", serif;
      font-weight:600;
      font-size: 18px;
    }

    .brand .tag{
      font-size: 12px;
      color: var(--muted);
      border-left: 1px solid rgba(31,26,24,.18);
      padding-left:10px;
      margin-left:2px;
    }

    .navActions{
      display:flex;
      gap:10px;
      align-items:center;
    }

    .pill{
      appearance:none;
      border:1px solid rgba(31,26,24,.14);
      background: rgba(255,255,255,.45);
      padding: 10px 12px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 13px;
      letter-spacing:.01em;
      cursor:pointer;
      transition: transform .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease;
      box-shadow: 0 8px 24px rgba(31,26,24,.06);
    }

    .pill:hover{
      transform: translateY(-1px);
      background: rgba(255,255,255,.72);
      border-color: rgba(214,90,117,.35);
      box-shadow: 0 14px 34px rgba(31,26,24,.10);
    }

    .pill:active{
      transform: translateY(0px) scale(.98);
    }

    .pill.primary{
      border-color: rgba(214,90,117,.34);
      background: linear-gradient(180deg, rgba(214,90,117,.14), rgba(214,90,117,.08));
    }

    .pill .dot{
      display:inline-block;
      width:8px; height:8px;
      border-radius:999px;
      margin-right:8px;
      background: radial-gradient(circle at 30% 30%, var(--blush), var(--rose));
      box-shadow: 0 0 0 3px rgba(214,90,117,.12);
      vertical-align:middle;
    }

    /* Hero */
    main{ position:relative; }
    .hero{
      padding: clamp(28px, 4.5vw, 54px) 0 30px;
    }

    .heroGrid{
      display:grid;
      grid-template-columns: 1.05fr .95fr;
      gap: clamp(18px, 3.5vw, 36px);
      align-items:stretch;
    }

    @media (max-width: 900px){
      .heroGrid{ grid-template-columns: 1fr; }
    }

    .headline{
      padding: clamp(14px, 2.2vw, 22px);
      border-radius: var(--radius);
      background:
        radial-gradient(900px 500px at 10% 0%, rgba(242,182,196,.22), transparent 55%),
        radial-gradient(900px 500px at 90% 30%, rgba(184,139,42,.14), transparent 55%),
        rgba(255,255,255,.42);
      border: 1px solid rgba(31,26,24,.10);
      box-shadow: var(--shadow);
      position:relative;
      overflow:hidden;
      min-height: 420px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .headline::after{
      content:"";
      position:absolute;
      inset:-2px;
      background:
        radial-gradient(10px 10px at 18% 22%, rgba(214,90,117,.35), transparent 60%),
        radial-gradient(12px 12px at 72% 26%, rgba(184,139,42,.28), transparent 60%),
        radial-gradient(12px 12px at 35% 78%, rgba(242,182,196,.40), transparent 60%),
        radial-gradient(10px 10px at 85% 72%, rgba(214,90,117,.20), transparent 60%);
      opacity:.65;
      pointer-events:none;
      filter: blur(.2px);
    }

    .kicker{
      display:flex;
      align-items:center;
      gap:10px;
      color: var(--muted);
      font-size: 13px;
      letter-spacing:.12em;
      text-transform:uppercase;
      position:relative;
      z-index:1;
    }

    .kicker .line{
      flex:1;
      height:1px;
      background: linear-gradient(90deg, rgba(31,26,24,.18), transparent);
    }

    h1{
      font-family:"Fraunces", serif;
      font-weight: 600;
      line-height: .98;
      letter-spacing: -0.02em;
      font-size: clamp(42px, 5.6vw, 72px);
      margin: 12px 0 12px;
      position:relative;
      z-index:1;
    }

    .sub{
      font-size: clamp(15px, 1.55vw, 18px);
      line-height: 1.6;
      color: var(--muted);
      max-width: 56ch;
      position:relative;
      z-index:1;
    }

    .heroCTA{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      align-items:center;
      margin-top: 18px;
      position:relative;
      z-index:1;
    }

    .btn{
      appearance:none;
      border:none;
      cursor:pointer;
      border-radius: 999px;
      padding: 12px 16px;
      font-weight: 700;
      letter-spacing:.01em;
      background: linear-gradient(135deg, rgba(214,90,117,.92), rgba(107,29,51,.92));
      color: #fff;
      box-shadow: 0 16px 40px rgba(107,29,51,.22);
      transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
    }
    .btn:hover{
      transform: translateY(-1px);
      box-shadow: 0 22px 56px rgba(107,29,51,.28);
      filter: saturate(1.05);
    }
    .btn:active{ transform: translateY(0) scale(.98); }

    .btnGhost{
      background: rgba(255,255,255,.55);
      color: var(--ink);
      border: 1px solid rgba(31,26,24,.14);
      box-shadow: 0 12px 30px rgba(31,26,24,.08);
    }

    .tinyNote{
      font-size: 12px;
      color: rgba(31,26,24,.62);
      margin-left: 6px;
    }

    /* Right panel: interactive letter */
    .letter{
      border-radius: var(--radius);
      border: 1px solid rgba(31,26,24,.10);
      background: rgba(255,255,255,.50);
      box-shadow: var(--shadow);
      overflow:hidden;
      min-height: 420px;
      display:flex;
      flex-direction:column;
    }

    .letterTop{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding: 16px 16px 12px;
      border-bottom: 1px solid rgba(31,26,24,.08);
      background: linear-gradient(180deg, rgba(255,255,255,.55), rgba(255,255,255,.35));
    }

    .stamp{
      display:flex;
      align-items:center;
      gap:10px;
      min-width: 0;
    }

    .seal{
      width: 36px; height:36px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 30% 30%, rgba(255,255,255,.65), transparent 55%),
        radial-gradient(circle at 70% 70%, rgba(0,0,0,.12), transparent 60%),
        conic-gradient(from 210deg, rgba(214,90,117,.95), rgba(184,139,42,.92), rgba(214,90,117,.92));
      box-shadow: 0 10px 26px rgba(107,29,51,.18);
      border: 1px solid rgba(31,26,24,.10);
      flex: 0 0 auto;
    }

    .stampText{
      min-width: 0;
    }
    .stampText strong{
      display:block;
      font-family:"Fraunces", serif;
      font-weight:600;
      letter-spacing:-.01em;
      font-size: 16px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .stampText span{
      display:block;
      font-size: 12px;
      color: var(--muted);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .counter{
      font-size: 12px;
      color: var(--muted);
      display:flex;
      gap:10px;
      align-items:center;
      white-space:nowrap;
    }

    .chip{
      border: 1px solid rgba(31,26,24,.12);
      background: rgba(255,255,255,.52);
      padding: 7px 10px;
      border-radius: 999px;
      box-shadow: 0 8px 18px rgba(31,26,24,.06);
    }

    .letterBody{
      padding: 18px 16px 16px;
      display:flex;
      flex-direction:column;
      gap: 12px;
      flex:1;
    }

    .letterP{
      margin:0;
      line-height:1.7;
      color: rgba(31,26,24,.78);
      font-size: 15px;
    }

    .type{
      font-family: "Fraunces", serif;
      color: var(--ink);
      font-size: 18px;
      line-height: 1.5;
      letter-spacing: -.01em;
      margin: 0;
    }

    .signature{
      margin-top:auto;
      padding-top: 10px;
      border-top: 1px dashed rgba(31,26,24,.18);
      display:flex;
      justify-content:space-between;
      align-items:flex-end;
      gap:14px;
    }

    .sigName{
      font-family:"Fraunces", serif;
      font-size: 22px;
      letter-spacing: -.02em;
      margin:0;
    }
    .sigSmall{
      margin: 2px 0 0;
      font-size: 12px;
      color: var(--muted);
    }

    .heartGlyph{
      width: 54px; height: 54px;
      flex: 0 0 auto;
      filter: drop-shadow(0 14px 22px rgba(107,29,51,.18));
    }

    /* Sections */
    section{
      padding: 30px 0;
    }

    .sectionTitle{
      display:flex;
      align-items:baseline;
      justify-content:space-between;
      gap:16px;
      margin-bottom: 14px;
    }

    h2{
      font-family:"Fraunces", serif;
      font-weight: 600;
      letter-spacing:-.02em;
      font-size: clamp(22px, 2.6vw, 34px);
      margin:0;
    }

    .hint{
      color: var(--muted);
      font-size: 13px;
      line-height:1.4;
      max-width: 52ch;
      text-align:right;
    }

    @media (max-width: 720px){
      .sectionTitle{ flex-direction:column; align-items:flex-start; }
      .hint{ text-align:left; }
    }

    /* Reasons: list/gallery justified -> tiles allowed */
    .reasons{
      display:grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
    }

    @media (max-width: 920px){
      .reasons{ grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 560px){
      .reasons{ grid-template-columns: 1fr; }
    }

    .reason{
      border-radius: 18px;
      border: 1px solid rgba(31,26,24,.10);
      background:
        radial-gradient(500px 220px at 20% 0%, rgba(242,182,196,.18), transparent 55%),
        rgba(255,255,255,.55);
      padding: 14px 14px 16px;
      box-shadow: 0 14px 40px rgba(31,26,24,.08);
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
      position:relative;
      overflow:hidden;
      min-height: 116px;
    }

    .reason:hover{
      transform: translateY(-2px);
      border-color: rgba(214,90,117,.28);
      box-shadow: 0 22px 62px rgba(31,26,24,.12);
    }

    .reasonNum{
      font-size: 12px;
      letter-spacing:.18em;
      text-transform:uppercase;
      color: rgba(31,26,24,.55);
    }

    .reason strong{
      display:block;
      font-family:"Fraunces", serif;
      font-size: 18px;
      margin-top: 6px;
      letter-spacing:-.01em;
    }

    .reason p{
      margin: 8px 0 0;
      color: rgba(31,26,24,.70);
      line-height:1.6;
      font-size: 14px;
    }

    /* Promise band */
    .promise{
      border-radius: var(--radius);
      border: 1px solid rgba(31,26,24,.10);
      background:
        linear-gradient(135deg, rgba(255,255,255,.55), rgba(255,255,255,.35)),
        radial-gradient(900px 420px at 0% 30%, rgba(214,90,117,.14), transparent 60%),
        radial-gradient(900px 420px at 100% 70%, rgba(184,139,42,.14), transparent 60%);
      box-shadow: var(--shadow);
      padding: 18px;
      display:grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 14px;
      align-items:center;
      overflow:hidden;
      position:relative;
    }

    .promise::before{
      content:"";
      position:absolute;
      inset:-1px;
      background:
        radial-gradient(10px 10px at 12% 24%, rgba(184,139,42,.35), transparent 60%),
        radial-gradient(12px 12px at 64% 18%, rgba(214,90,117,.28), transparent 60%),
        radial-gradient(11px 11px at 88% 68%, rgba(242,182,196,.40), transparent 60%);
      opacity:.55;
      pointer-events:none;
    }

    @media (max-width: 860px){
      .promise{ grid-template-columns: 1fr; }
    }

    .promise h3{
      font-family:"Fraunces", serif;
      font-weight:600;
      letter-spacing:-.02em;
      font-size: clamp(20px, 2.2vw, 28px);
      margin:0 0 8px;
      position:relative;
      z-index:1;
    }
    .promise p{
      margin:0;
      color: rgba(31,26,24,.72);
      line-height:1.7;
      position:relative;
      z-index:1;
    }

    .promiseControls{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      justify-content:flex-end;
      position:relative;
      z-index:1;
    }
    @media (max-width: 860px){
      .promiseControls{ justify-content:flex-start; }
    }

    /* Footer */
    footer{
      padding: 26px 0 40px;
      color: rgba(31,26,24,.68);
    }
    .footerInner{
      border-top: 1px solid rgba(31,26,24,.10);
      padding-top: 16px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:14px;
      flex-wrap:wrap;
    }
    .small{
      font-size: 12px;
      line-height:1.6;
    }

    /* Reveal animations */
    .reveal{
      opacity:0;
      transform: translateY(14px);
    }
    .reveal.in{
      animation: rise .7s cubic-bezier(.2,.8,.2,1) forwards;
    }
    @keyframes rise{
      to { opacity:1; transform: translateY(0); }
    }

    /* Modal */
    dialog{
      border:none;
      border-radius: 22px;
      padding:0;
      width:min(680px, calc(100% - 24px));
      box-shadow: 0 30px 90px rgba(31,26,24,.22);
      background: rgba(255,255,255,.78);
      backdrop-filter: blur(10px);
      color: var(--ink);
    }
    dialog::backdrop{
      background: rgba(31,26,24,.45);
      backdrop-filter: blur(2px);
    }
    .modal{
      padding: 16px;
      border: 1px solid rgba(31,26,24,.10);
      border-radius: 22px;
      background:
        radial-gradient(900px 420px at 10% 0%, rgba(242,182,196,.20), transparent 60%),
        radial-gradient(900px 420px at 90% 60%, rgba(184,139,42,.14), transparent 60%),
        rgba(255,255,255,.60);
    }
    .modalTop{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(31,26,24,.10);
    }
    .modalTop h3{
      margin:0;
      font-family:"Fraunces", serif;
      font-size: 22px;
      letter-spacing:-.02em;
      font-weight:600;
    }
    .closeX{
      appearance:none;
      border: 1px solid rgba(31,26,24,.14);
      background: rgba(255,255,255,.55);
      border-radius: 999px;
      padding: 8px 10px;
      cursor:pointer;
      font-weight:800;
      line-height:1;
      transition: transform .16s ease, background .16s ease;
    }
    .closeX:hover{ transform: translateY(-1px); background: rgba(255,255,255,.75); }
    .closeX:active{ transform: translateY(0) scale(.98); }

    .form{
      padding-top: 12px;
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 640px){
      .form{ grid-template-columns: 1fr; }
    }
    label{
      display:block;
      font-size: 12px;
      color: rgba(31,26,24,.68);
      margin-bottom: 6px;
    }
    input, textarea{
      width:100%;
      border-radius: 14px;
      border: 1px solid rgba(31,26,24,.14);
      background: rgba(255,255,255,.62);
      padding: 11px 12px;
      font: inherit;
      color: var(--ink);
      outline:none;
      transition: border-color .16s ease, box-shadow .16s ease, background .16s ease;
    }
    textarea{ min-height: 96px; resize: vertical; grid-column: 1 / -1; }
    input:focus, textarea:focus{
      border-color: rgba(214,90,117,.42);
      box-shadow: 0 0 0 4px rgba(214,90,117,.14);
      background: rgba(255,255,255,.78);
    }
    .modalActions{
      display:flex;
      gap:10px;
      align-items:center;
      justify-content:flex-end;
      padding-top: 10px;
      grid-column: 1 / -1;
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce){
      .reveal{ opacity:1; transform:none; }
      .reveal.in{ animation:none; }
      .pill, .btn, .reason, .closeX{ transition:none; }
    }
  </style>
</head>

<body>
  <header aria-label="Top navigation">
    <div class="wrap">
      <div class="nav">
        <div class="brand" aria-label="Site title">
          <span class="sig">A small love letter</span>
          <span class="tag">written with intention</span>
        </div>
        <div class="navActions">
          <button class="pill" id="openPersonalize" type="button" aria-haspopup="dialog" aria-controls="personalizeDialog">
            <span class="dot" aria-hidden="true"></span>Personalize
          </button>
          <button class="pill primary" id="scrollToReasons" type="button">
            Read why
          </button>
        </div>
      </div>
    </div>
  </header>

  <main>
    <div class="wrap hero">
      <div class="heroGrid">
        <section class="headline reveal" aria-label="Hero message">
          <div>
            <div class="kicker">
              <span>For</span>
              <span class="line" aria-hidden="true"></span>
              <span id="gfNameKicker">my favorite person</span>
            </div>

            <h1>
              I love you<br/>
              <span style="color: var(--wine);">so much.</span>
            </h1>

            <p class="sub" id="heroSub">
              Not in a “big dramatic moment” way only—also in the quiet way.
              The everyday way. The way that shows up, chooses you, and keeps choosing you.
            </p>

            <div class="heroCTA" role="group" aria-label="Primary actions">
              <button class="btn" id="revealLine" type="button">Open the next sentence</button>
              <button class="btn btnGhost" id="copyLink" type="button" title="Copies a tiny message you can send">
                Copy a sweet text
              </button>
              <span class="tinyNote" id="copyStatus" aria-live="polite"></span>
            </div>
          </div>

          <div class="tinyNote" style="position:relative; z-index:1;">
            Tip: personalize names & a date in the top-right.
          </div>
        </section>

        <aside class="letter reveal" aria-label="Love letter panel">
          <div class="letterTop">
            <div class="stamp">
              <div class="seal" aria-hidden="true"></div>
              <div class="stampText">
                <strong id="dearLine">To you, love</strong>
                <span id="dateLine">Today</span>
              </div>
            </div>
            <div class="counter" aria-label="Love counter">
              <span class="chip"><span aria-hidden="true">♥</span> <span id="loveCount">0</span></span>
              <span class="chip" id="sinceChip">since always</span>
            </div>
          </div>

          <div class="letterBody">
            <p class="letterP">If you ever wonder how I feel, here’s the simplest truth:</p>

            <p class="type" id="typedLine" aria-live="polite">
              I love you for the way you exist in the world—soft, strong, and completely you.
            </p>

            <p class="letterP" id="extraLine" hidden>
              I love your laugh, your patience, your little habits, and even the parts you don’t always see as special—
              because they’re the exact things that make you <em>you</em>.
            </p>

            <div class="signature" aria-label="Signature">
              <div>
                <p class="sigName" id="fromLine">— me</p>
                <p class="sigSmall" id="psLine">P.S. You are my best day.</p>
              </div>

              <!-- Inline SVG heart (no external images) -->
              <svg class="heartGlyph" viewBox="0 0 64 64" role="img" aria-label="A heart">
                <defs>
                  <linearGradient id="hg" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0" stop-color="#f2b6c4"/>
                    <stop offset="0.55" stop-color="#d65a75"/>
                    <stop offset="1" stop-color="#6b1d33"/>
                  </linearGradient>
                </defs>
                <path d="M32 56s-18.8-11.8-26-24.3C-1.2 19.2 7.4 6.7 20.8 8.5c4.9.7 8.6 3.8 11.2 7.6 2.6-3.8 6.3-6.9 11.2-7.6 13.4-1.8 22 10.7 14.8 23.2C50.8 44.2 32 56 32 56z"
                      fill="url(#hg)" stroke="rgba(31,26,24,.12)" stroke-width="1.2"/>
                <path d="M18 20c2-4 6.7-7 11.7-5.4" fill="none" stroke="rgba(255,255,255,.45)" stroke-linecap="round" stroke-width="2"/>
              </svg>
            </div>
          </div>
        </aside>
      </div>
    </div>

    <section aria-label="Reasons section">
      <div class="wrap">
        <div class="sectionTitle">
          <h2 class="reveal">A few reasons (out of a million)</h2>
          <p class="hint reveal">Tap a reason to make it glow. Add your own in “Personalize”.</p>
        </div>

        <div class="reasons" id="reasonsGrid">
          <article class="reason reveal" tabindex="0" role="button" aria-label="Reason 1">
            <div class="reasonNum">Reason 01</div>
            <strong>Your presence</strong>
            <p>You make ordinary moments feel safe, warm, and worth remembering.</p>
          </article>
          <article class="reason reveal" tabindex="0" role="button" aria-label="Reason 2">
            <div class="reasonNum">Reason 02</div>
            <strong>Your heart</strong>
            <p>You care in a way that’s gentle, real, and never performative.</p>
          </article>
          <article class="reason reveal" tabindex="0" role="button" aria-label="Reason 3">
            <div class="reasonNum">Reason 03</div>
            <strong>Your mind</strong>
            <p>The way you think is beautiful—curious, sharp, and uniquely yours.</p>
          </article>
          <article class="reason reveal" tabindex="0" role="button" aria-label="Reason 4">
            <div class="reasonNum">Reason 04</div>
            <strong>Your laugh</strong>
            <p>It changes the temperature of the entire room. I chase it on purpose.</p>
          </article>
          <article class="reason reveal" tabindex="0" role="button" aria-label="Reason 5">
            <div class="reasonNum">Reason 05</div>
            <strong>Your softness & strength</strong>
            <p>You’re tender without being fragile. Brave without being loud.</p>
          </article>
          <article class="reason reveal" tabindex="0" role="button" aria-label="Reason 6">
            <div class="reasonNum">Reason 06</div>
            <strong>Us</strong>
            <p>Even on hard days, I still want to come back to you—every time.</p>
          </article>
        </div>
      </div>
    </section>

    <section aria-label="Promise section">
      <div class="wrap">
        <div class="promise reveal">
          <div>
            <h3 id="promiseTitle">A promise, said simply</h3>
            <p id="promiseBody">
              I’m not here for the highlight reel only. I’m here for the real thing:
              the messy days, the quiet days, the growing days—and the forever kinds of days.
            </p>
          </div>
          <div class="promiseControls" role="group" aria-label="Promise actions">
            <button class="pill" id="toggleExtra" type="button">Add a little more</button>
            <button class="pill primary" id="confetti" type="button">Make it sparkle</button>
          </div>
        </div>
      </div>
    </section>

    <footer aria-label="Footer">
      <div class="wrap">
        <div class="footerInner">
          <div class="small">
            <strong style="font-family:'Fraunces', serif; font-weight:600;">Made for one person only.</strong><br/>
            <span id="footerLine">If you’re reading this: I love you. Still. Always.</span>
          </div>
          <div class="small">
            <span class="chip" aria-label="A small reminder">Keep this page. Open it on hard days.</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Personalize Modal -->
    <dialog id="personalizeDialog" aria-label="Personalize the love letter">
      <div class="modal">
        <div class="modalTop">
          <div>
            <h3>Personalize</h3>
            <div class="small" style="color: rgba(31,26,24,.70); margin-top:4px;">
              Fill in a few details and the letter updates instantly.
            </div>
          </div>
          <button class="closeX" id="closePersonalize" type="button" aria-label="Close dialog">✕</button>
        </div>

        <form class="form" id="personalizeForm" autocomplete="on">
          <div>
            <label for="gfName">Her name</label>
            <input id="gfName" name="gfName" placeholder="e.g., Sofia" />
          </div>
          <div>
            <label for="yourName">Your name</label>
            <input id="yourName" name="yourName" placeholder="e.g., Alex" />
          </div>
          <div>
            <label for="sinceDate">Since date (optional)</label>
            <input id="sinceDate" name="sinceDate" type="date" />
          </div>
          <div>
            <label for="shortPS">P.S. line</label>
            <input id="shortPS" name="shortPS" placeholder="e.g., You’re my favorite hello." />
          </div>

          <div style="grid-column: 1 / -1;">
            <label for="customReason">Add one custom reason</label>
            <textarea id="customReason" name="customReason" placeholder="Write something only she would recognize…"></textarea>
          </div>

          <div class="modalActions">
            <button class="pill" type="reset" id="resetForm">Reset</button>
            <button class="pill primary" type="button" id="applyPersonalize">
              Apply
            </button>
          </div>
        </form>
      </div>
    </dialog>
  </main>

  <script>
    // ---------- Helpers ----------
    const $ = (sel, root = document) => root.querySelector(sel);
    const $$ = (sel, root = document) => Array.from(root.querySelectorAll(sel));

    const state = {
      gfName: "",
      yourName: "",
      sinceDate: "",
      ps: "",
      customReason: ""
    };

    function formatSince(dateStr){
      if(!dateStr) return "since always";
      const d = new Date(dateStr + "T00:00:00");
      if(Number.isNaN(d.getTime())) return "since always";
      const fmt = new Intl.DateTimeFormat(undefined, { year: "numeric", month: "short", day: "numeric" });
      return `since ${fmt.format(d)}`;
    }

    function formatToday(){
      const fmt = new Intl.DateTimeFormat(undefined, { weekday: "short", year: "numeric", month: "short", day: "numeric" });
      return fmt.format(new Date());
    }

    // ---------- Reveal on scroll ----------
    const revealEls = $$(".reveal");
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if(e.isIntersecting){
          const idx = revealEls.indexOf(e.target);
          e.target.classList.add("in");
          e.target.style.animationDelay = `${Math.min(idx * 70, 420)}ms`;
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });

    revealEls.forEach(el => io.observe(el));

    // ---------- Love counter (delight) ----------
    let love = 0;
    const loveCount = $("#loveCount");
    const loveTimer = setInterval(() => {
      love += 1;
      loveCount.textContent = String(love);
      if(love >= 143) clearInterval(loveTimer); // "I love you" number
    }, 32);

    // ---------- Hero interactions ----------
    const typedLine = $("#typedLine");
    const extraLine = $("#extraLine");
    const revealLineBtn = $("#revealLine");

    const extraSentences = [
      "You feel like home to me—no matter where we are.",
      "I’m proud of you, and I’m proud to love you.",
      "I choose you in the little moments, not just the big ones.",
      "If love is a language, you’re my favorite sentence."
    ];
    let idx = 0;

    revealLineBtn.addEventListener("click", () => {
      idx = (idx + 1) % extraSentences.length;
      typedLine.style.opacity = 0;
      typedLine.style.transform = "translateY(6px)";
      setTimeout(() => {
        typedLine.textContent = extraSentences[idx];
        typedLine.style.opacity = 1;
        typedLine.style.transform = "translateY(0)";
      }, 170);

      extraLine.hidden = false;
    });

    $("#toggleExtra").addEventListener("click", () => {
      extraLine.hidden = !extraLine.hidden;
      $("#toggleExtra").textContent = extraLine.hidden ? "Add a little more" : "Keep it simple";
    });

    // ---------- Reasons: tap to "glow" ----------
    function toggleGlow(el){
      const on = el.getAttribute("data-on") === "1";
      el.setAttribute("data-on", on ? "0" : "1");
      el.style.boxShadow = on
        ? "0 14px 40px rgba(31,26,24,.08)"
        : "0 22px 70px rgba(214,90,117,.18)";
      el.style.borderColor = on
        ? "rgba(31,26,24,.10)"
        : "rgba(214,90,117,.34)";
    }

    $$("#reasonsGrid .reason").forEach((r) => {
      r.addEventListener("click", () => toggleGlow(r));
      r.addEventListener("keydown", (e) => {
        if(e.key === "Enter" || e.key === " "){
          e.preventDefault();
          toggleGlow(r);
        }
      });
    });

    // ---------- Scroll to reasons ----------
    $("#scrollToReasons").addEventListener("click", () => {
      const target = $("section[aria-label='Reasons section']");
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    // ---------- Copy a sweet text ----------
    $("#copyLink").addEventListener("click", async () => {
      const gf = state.gfName?.trim() || "love";
      const from = state.yourName?.trim() || "me";
      const msg = `Hey ${gf}. Just wanted to say I love you so much. In the quiet way. In the everyday way. — ${from}`;
      try{
        await navigator.clipboard.writeText(msg);
        $("#copyStatus").textContent = "Copied.";
        setTimeout(() => $("#copyStatus").textContent = "", 1800);
      }catch(err){
        $("#copyStatus").textContent = "Couldn’t copy (browser blocked it).";
        setTimeout(() => $("#copyStatus").textContent = "", 2200);
      }
    });

    // ---------- Sparkle (CSS + DOM confetti hearts) ----------
    $("#confetti").addEventListener("click", () => {
      const n = 22;
      const root = document.body;

      for(let i=0; i<n; i++){
        const s = document.createElement("span");
        s.textContent = Math.random() > 0.5 ? "♥" : "✦";
        s.setAttribute("aria-hidden", "true");
        s.style.position = "fixed";
        s.style.left = (10 + Math.random()*80) + "vw";
        s.style.top = "-6vh";
        s.style.fontSize = (12 + Math.random()*18) + "px";
        s.style.color = Math.random() > 0.5 ? "rgba(214,90,117,.95)" : "rgba(184,139,42,.92)";
        s.style.textShadow = "0 10px 24px rgba(31,26,24,.18)";
        s.style.zIndex = 9999;
        s.style.pointerEvents = "none";
        const drift = (Math.random()*2 - 1) * 18;

        s.animate([
          { transform: `translate3d(0,0,0) rotate(0deg)`, opacity: 0 },
          { opacity: 1, offset: 0.12 },
          { transform: `translate3d(${drift}vw, 86vh, 0) rotate(${(Math.random()*240 - 120)}deg)`, opacity: 0.0 }
        ], {
          duration: 1600 + Math.random()*900,
          easing: "cubic-bezier(.2,.8,.2,1)"
        });

        root.appendChild(s);
        setTimeout(() => s.remove(), 2600);
      }
    });

    // ---------- Personalize dialog ----------
    const dlg = $("#personalizeDialog");
    const openBtn = $("#openPersonalize");
    const closeBtn = $("#closePersonalize");
    const applyBtn = $("#applyPersonalize");
    const form = $("#personalizeForm");

    function applyState(){
      const gf = state.gfName.trim();
      const you = state.yourName.trim();
      const ps = state.ps.trim();
      const since = state.sinceDate;

      $("#gfNameKicker").textContent = gf ? gf : "my favorite person";
      $("#dearLine").textContent = gf ? `To ${gf}` : "To you, love";
      $("#fromLine").textContent = you ? `— ${you}` : "— me";
      $("#psLine").textContent = ps ? `P.S. ${ps}` : "P.S. You are my best day.";
      $("#sinceChip").textContent = formatSince(since);
      $("#dateLine").textContent = formatToday();

      // Custom reason insertion (as a gallery item: allowed)
      const existing = $("#customReasonTile");
      const text = state.customReason.trim();

      if(text && !existing){
        const tile = document.createElement("article");
        tile.className = "reason reveal in";
        tile.id = "customReasonTile";
        tile.tabIndex = 0;
        tile.setAttribute("role", "button");
        tile.setAttribute("aria-label", "Custom reason");
        tile.innerHTML = `
          <div class="reasonNum">A reason I wrote</div>
          <strong>${gf ? `Because you’re you, ${gf}` : "Because you’re you"}</strong>
          <p>${escapeHTML(text)}</p>
        `;
        $("#reasonsGrid").prepend(tile);

        tile.addEventListener("click", () => toggleGlow(tile));
        tile.addEventListener("keydown", (e) => {
          if(e.key === "Enter" || e.key === " "){
            e.preventDefault();
            toggleGlow(tile);
          }
        });
      } else if(text && existing){
        existing.querySelector("strong").textContent = gf ? `Because you’re you, ${gf}` : "Because you’re you";
        existing.querySelector("p").textContent = text;
      } else if(!text && existing){
        existing.remove();
      }

      // Slightly personalize hero sub line if name exists
      const heroSub = $("#heroSub");
      if(gf){
        heroSub.textContent = `Not in a “big dramatic moment” way only—also in the quiet way. The everyday way. The way that shows up, chooses you, and keeps choosing you, ${gf}.`;
      }else{
        heroSub.textContent = `Not in a “big dramatic moment” way only—also in the quiet way. The everyday way. The way that shows up, chooses you, and keeps choosing you.`;
      }

      // Footer
      $("#footerLine").textContent = gf
        ? `If you’re reading this, ${gf}: I love you. Still. Always.`
        : "If you’re reading this: I love you. Still. Always.";
    }

    function escapeHTML(str){
      return str.replace(/[&<>"']/g, (m) => ({
        "&":"&amp;",
        "<":"&lt;",
        ">":"&gt;",
        '"':"&quot;",
        "'":"&#039;"
      }[m]));
    }

    openBtn.addEventListener("click", () => {
      if(typeof dlg.showModal === "function") dlg.showModal();
      else dlg.setAttribute("open",""); // fallback
      // prefill inputs
      $("#gfName").value = state.gfName;
      $("#yourName").value = state.yourName;
      $("#sinceDate").value = state.sinceDate;
      $("#shortPS").value = state.ps;
      $("#customReason").value = state.customReason;
      setTimeout(() => $("#gfName").focus(), 30);
    });

    closeBtn.addEventListener("click", () => dlg.close());

    dlg.addEventListener("click", (e) => {
      const rect = dlg.getBoundingClientRect();
      const inDialog = (
        e.clientX >= rect.left && e.clientX <= rect.right &&
        e.clientY >= rect.top && e.clientY <= rect.bottom
      );
      if(!inDialog) dlg.close();
    });

    applyBtn.addEventListener("click", () => {
      state.gfName = $("#gfName").value || "";
      state.yourName = $("#yourName").value || "";
      state.sinceDate = $("#sinceDate").value || "";
      state.ps = $("#shortPS").value || "";
      state.customReason = $("#customReason").value || "";
      applyState();
      dlg.close();
    });

    $("#resetForm").addEventListener("click", () => {
      state.gfName = "";
      state.yourName = "";
      state.sinceDate = "";
      state.ps = "";
      state.customReason = "";
      setTimeout(() => applyState(), 0);
    });

    // Initialize
    applyState();
  </script>
</body>
</html>
